## Parent Drawer Inert Pattern

When a child dialog opens from inside an `ERPDrawerForm`, the parent drawer MUST become
inert (non-interactive) and visibly dimmed.

### Pattern (required for any drawer with child dialogs)

```tsx
// parent-form-drawer.tsx
const [childDialogOpen, setChildDialogOpen] = useState(false);
const handleChildOpen = useCallback((open: boolean) => setChildDialogOpen(open), []);

<ERPDrawerForm ...>
  <div
    inert={childDialogOpen || undefined}
    className={cn(
      "flex flex-col flex-1 overflow-hidden min-h-0",
      "transition-opacity duration-200",
      childDialogOpen && "opacity-50"
    )}
  >
    <ERPDrawerSectionNav ... />
    <form ...>
      <ERPDrawerBody>
        <SomeTab partyId={id} onChildOpen={handleChildOpen} />
      </ERPDrawerBody>
      <ERPFormFooter ... />
    </form>
  </div>
</ERPDrawerForm>
```

### Tab Pattern

```tsx
// Each tab with a child dialog
type MyTabProps = {
  partyId: number;
  disabled?: boolean;
  onChildOpen?: (open: boolean) => void;   // ← required
};

const [isDialogOpen, setIsDialogOpen] = useState(false);

// ← use this helper for all open/close calls:
const setDialogOpen = (open: boolean) => {
  setIsDialogOpen(open);
  onChildOpen?.(open);
};

<ERPChildDialogForm
  open={isDialogOpen}
  onOpenChange={setDialogOpen}   // ← NOT setIsDialogOpen
  ...
>
```

