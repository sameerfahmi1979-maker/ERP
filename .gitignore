# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# planning / AI prompt docs and personal test documents (not part of the app)
ChatGPT/

# Design archive — excluded from VCS; contains node_modules with flagged packages
UIUX_Design/

# Temporary scripts used for one-off migrations / fixes
scripts/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
