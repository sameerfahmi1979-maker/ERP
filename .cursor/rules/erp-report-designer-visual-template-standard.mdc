## Server Action Requirements

Every action in `report-designer-layout.ts` and `report-designer-test.ts` must:

```typescript
// 1. Auth check
const authCtx = await getAuthContext();
if (!authCtx) return { success: false, error: "Not authenticated" };

// 2. Permission gate BEFORE createAdminClient()
if (!hasPermission(authCtx, "reports", "manage")) { /* reject */ }

// 3. Only after permission check:
const supabase = createAdminClient();

// 4. Zod validation
const parsed = MySchema.safeParse(input);
if (!parsed.success) { /* reject with errors */ }

// 5. Governance guard for writes
if (!EDITABLE_GOVERNANCE_STATUSES.includes(template.governance_status)) { /* reject */ }

// 6. Audit with structural metadata only
await logAudit({ action, entity_type, entity_id, payload: structuralMetaOnly });

// 7. Revalidate
revalidatePath("/admin/reports/templates");
```

