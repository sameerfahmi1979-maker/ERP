NEXT_PUBLIC_SUPABASE_URL=https://mmiefuieduzdiiwnqpie.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE_ONLY_FOR_SERVER_TASKS_NEVER_EXPOSE
SUPABASE_DB_PASSWORD=PASTE_DB_PASSWORD_HERE_ONLY_IF_NEEDED_BY_CLI

# ============================================================================
# Application base URL (used for invite links, email redirects, etc.)
# Development: http://localhost:3000
# Production:  https://erp.algt.net
# ============================================================================
NEXT_PUBLIC_SITE_URL=https://erp.algt.net

# ============================================================================
# Public signup gate (ERP USERS.1)
# Controls whether /signup is accessible and whether the login page shows
# the "Create account" link.
# Default (not set / false): signup is DISABLED — production default.
# Set to true only for local development or explicit onboarding sessions.
# ============================================================================
SIGNUP_ENABLED=false
NEXT_PUBLIC_SIGNUP_ENABLED=false

# ============================================================================
# Microsoft Graph Email Provider (Phase 002E.3A)
# ============================================================================
# Azure App Registration credentials for sending emails via Microsoft Graph API
# See ERP_BASE_002E_3_MICROSOFT_GRAPH_SETUP_GUIDE.md for setup instructions

# Required: Azure AD Tenant ID (from App Registration Overview page)
MICROSOFT_TENANT_ID=PASTE_TENANT_ID_HERE

# Required: Application (Client) ID (from App Registration Overview page)
MICROSOFT_CLIENT_ID=PASTE_CLIENT_ID_HERE

# Required: Client Secret (from App Registration > Certificates & secrets)
# IMPORTANT: Copy secret value immediately when created (shown once only)
MICROSOFT_CLIENT_SECRET=PASTE_CLIENT_SECRET_HERE

# Required: Sender email address (must be valid Microsoft 365 mailbox)
# Examples: noreply@yourdomain.com, erp@yourdomain.com, system@yourdomain.com
MICROSOFT_MAIL_SENDER=erp@yourdomain.com

# Optional: Microsoft Graph API base URL (default: https://graph.microsoft.com/v1.0)
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# Optional: Save sent emails to sender's Sent Items folder (default: true)
MICROSOFT_MAIL_SAVE_TO_SENT_ITEMS=true

# Optional: Maximum attachment size in MB (default: 10)
# Note: Microsoft Graph typically allows up to 25 MB total message size
MICROSOFT_MAIL_MAX_ATTACHMENT_MB=10

# Optional: Maximum total recipients (To + CC + BCC) (default: 20)
MICROSOFT_MAIL_MAX_RECIPIENTS=20
