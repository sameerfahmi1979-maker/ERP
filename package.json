{
  "name": "erp-foundation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 NODE_OPTIONS=--max-old-space-size=16384 next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=16384 next build",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=16384 next start",
    "lint": "eslint",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=16384 tsc --noEmit",
    "memory:check": "cross-env NODE_OPTIONS=--max-old-space-size=16384 node scripts/check-node-memory.mjs",
    "bootstrap:admin": "cross-env NODE_OPTIONS=--max-old-space-size=16384 node --env-file=.env.local scripts/bootstrap-admin.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 playwright test",
    "test:e2e:headed": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 playwright test --headed"
